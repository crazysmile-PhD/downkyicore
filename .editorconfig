root = true

[*.{cs,csproj,props,targets,axaml,json,yml,yaml,ps1,sh}]
charset = utf-8
insert_final_newline = true
trim_trailing_whitespace = true

[*.cs]
indent_style = space
indent_size = 4
dotnet_sort_system_directives_first = true
dotnet_separate_import_directive_groups = false
csharp_using_directive_placement = outside_namespace:suggestion

# Security rules cleaned in PR 02. Minimal source suppressions are documented in docs/maintenance.md.
dotnet_diagnostic.CA2100.severity = error
dotnet_diagnostic.CA5351.severity = error
dotnet_diagnostic.CA5373.severity = error
dotnet_diagnostic.CA5401.severity = error

# Async, disposal, exception, and lifecycle rules cleaned in PR 02.
dotnet_diagnostic.CA1001.severity = error
dotnet_diagnostic.CA1031.severity = error
dotnet_diagnostic.CA1032.severity = error
dotnet_diagnostic.CA1058.severity = error
dotnet_diagnostic.CA1063.severity = error
dotnet_diagnostic.CA1816.severity = error
dotnet_diagnostic.CA1849.severity = error
dotnet_diagnostic.CA1850.severity = error
dotnet_diagnostic.CA1872.severity = error
dotnet_diagnostic.CA2000.severity = error
dotnet_diagnostic.CA2007.severity = error
dotnet_diagnostic.CA2008.severity = error
dotnet_diagnostic.CA2025.severity = error
dotnet_diagnostic.CA2213.severity = error
dotnet_diagnostic.CA2214.severity = error

[*.{csproj,props,targets,axaml,json,yml,yaml}]
indent_style = space
indent_size = 2

[*.md]
charset = utf-8
insert_final_newline = true
trim_trailing_whitespace = false
