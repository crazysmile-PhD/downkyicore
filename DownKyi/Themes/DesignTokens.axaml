<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <x:Double x:Key="DownKyiFontSizeCaption">12</x:Double>
    <x:Double x:Key="DownKyiFontSizeBody">13</x:Double>
    <x:Double x:Key="DownKyiFontSizeTitle">18</x:Double>

    <x:Double x:Key="DownKyiSpacingSmall">4</x:Double>
    <x:Double x:Key="DownKyiSpacingMedium">8</x:Double>
    <x:Double x:Key="DownKyiSpacingLarge">16</x:Double>
    <Thickness x:Key="DownKyiControlPadding">12,6</Thickness>
    <Thickness x:Key="DownKyiHeaderPadding">8,2</Thickness>
    <Thickness x:Key="DownKyiHeaderMargin">8,0,0,0</Thickness>

    <CornerRadius x:Key="DownKyiRadiusSmall">4</CornerRadius>
    <CornerRadius x:Key="DownKyiRadiusMedium">8</CornerRadius>
    <CornerRadius x:Key="DownKyiRadiusLarge">12</CornerRadius>
    <BoxShadows x:Key="DownKyiElevationLow">0 1 3 0 #26000000</BoxShadows>

    <x:Double x:Key="DownKyiControlMinHeight">32</x:Double>
    <x:Double x:Key="DownKyiProgressThickness">8</x:Double>
</ResourceDictionary>
